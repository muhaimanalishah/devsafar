---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, tag } = Astro.props;

const formattedDate = pubDate.toISOString().split('T')[0];
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div class="noise"></div>
    <Header />
    <main>
      <aside class="toc">
        <div class="toc-title">./index</div>
        <slot name="toc" />
      </aside>

      <article class="post-body">
        <header class="post-header">
          <div class="post-meta">
            <span class={`tag ${tag}`}>{tag}</span>
            <span class="date">{formattedDate}</span>
          </div>
          <h1>{title}</h1>
          <p class="lead">{description}</p>
        </header>
        <div class="post-content">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    flex: 1;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 4rem;
    padding: 4rem 5vw;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }
  .toc {
    position: sticky;
    top: 6rem;
    height: fit-content;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .toc-title {
    color: var(--text);
    margin-bottom: 1rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    font-size: 0.85rem;
  }
  .tag {
    padding: 0.2rem 0.5rem;
    font-weight: 800;
    text-transform: uppercase;
  }
  .tag.tutorial { background: var(--neon); color: var(--bg); }
  .tag.article { background: var(--article); color: #fff; }
  .date { color: var(--muted); }
  h1 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-transform: lowercase;
  }
  .lead {
    font-size: 1.1rem;
    color: #aaa;
    border-left: 2px solid var(--neon);
    padding-left: 1rem;
    margin-bottom: 3rem;
  }
  .post-content :global(h2) {
    font-size: 1.5rem;
    margin: 3rem 0 1rem;
    text-transform: lowercase;
    color: var(--text);
    display: flex;
    align-items: center;
  }
  .post-content :global(h2)::before { content: "> "; color: var(--neon); }
  .post-content :global(p) { margin-bottom: 1.5rem; color: #ccc; }
  .post-content :global(pre) {
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .post-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
  }
  @media (max-width: 800px) {
    main { grid-template-columns: 1fr; padding: 2rem 5vw; }
    .toc { position: static; margin-bottom: 3rem; border-bottom: 1px dashed var(--border); padding-bottom: 2rem; }
  }
</style>