---
const pathname = Astro.url.pathname;
---

<header>
  <nav>
    <div class="prompt">
      [muhaiman@devsafar]$
      {pathname === "/blog" && <span>ls -la ./writing </span>}
      {pathname.startsWith("/blog/") && <span>cd content/posts </span>}
      {pathname === "/about" && <span>whoami </span>}
      <span class="blink">_</span>
    </div>
    <div class="links">
      <a href="/" class={pathname === "/" ? "active" : ""}>home</a>
      <a href="/blog" class={pathname.startsWith("/blog") ? "active" : ""}
        >writing</a
      >
      <a href="/about" class={pathname === "/about" ? "active" : ""}>about</a>
    </div>
  </nav>
</header>

<script>
  let lastY = 0;
  let delta = 0;
  const header = document.querySelector("header");

  window.addEventListener("scroll", () => {
    const currentY = window.scrollY;
    delta += lastY - currentY;

    if (currentY > lastY && currentY > 100) {
      header?.classList.add("hidden");
      delta = 0;
    } else if (delta > 10) {
      header?.classList.remove("hidden");
      delta = 0;
    }

    lastY = currentY;
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: transform 0.3s ease;
  }

  header.hidden {
    transform: translateY(-100%);
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 5vw;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    text-transform: lowercase;
    background: rgba(5, 5, 5, 0.9);
    backdrop-filter: blur(10px);
  }
  .prompt {
    color: var(--neon);
    font-weight: 700;
  }
  .blink {
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .links a {
    color: var(--muted);
    text-decoration: none;
    margin-left: 2rem;
    transition: color 0.2s;
  }
  .links a:hover,
  .links a.active {
    color: var(--text);
  }
  @media (max-width: 600px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .links {
      width: 100%;
      display: flex;
      justify-content: center;
      gap: 1.5rem;
    }
    .links a {
      margin-left: 0;
    }
  }
</style>
