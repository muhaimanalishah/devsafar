---
const pathname = Astro.url.pathname;
---

<header>
  <nav>
    <div class="prompt">
      [muhaiman@devsafar ~]$ 
      {pathname === '/' && <span>_</span>}
      {pathname.startsWith('/blog') && <span>cd content/posts </span>}
      {pathname === '/about' && <span>whoami </span>}
      <span class="blink">_</span>
    </div>
    <div class="links">
      <a href="/" class={pathname === '/' ? 'active' : ''}>home</a>
      <a href="/blog" class={pathname.startsWith('/blog') ? 'active' : ''}>writing</a>
      <a href="/about" class={pathname === '/about' ? 'active' : ''}>about</a>
    </div>
  </nav>
</header>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    padding: 1.5rem 5vw;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    text-transform: lowercase;
    position: sticky;
    top: 0;
    background: rgba(5, 5, 5, 0.9);
    backdrop-filter: blur(10px);
    z-index: 100;
  }
  .prompt { color: var(--neon); font-weight: 700; }
  .blink { animation: blink 1s step-end infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  .links a {
    color: var(--muted);
    text-decoration: none;
    margin-left: 2rem;
    transition: color 0.2s;
  }
  .links a:hover, .links a.active { color: var(--text); }
</style>