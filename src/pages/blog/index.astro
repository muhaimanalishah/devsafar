---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import '../../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <div class="noise"></div>
    <Header />
    <main>
      <h1>archive.</h1>
      <div class="filters">
        <button class="filter-btn active" data-filter="all">all</button>
        <button class="filter-btn" data-filter="tutorial">tutorials</button>
        <button class="filter-btn" data-filter="article">articles</button>
      </div>
      
      <div class="log-list" id="log-list">
        {posts.map(post => {
          const date = post.data.pubDate.toISOString().split('T')[0];
          return (
            <a href={`/blog/${post.id}`} class="log-row" data-tag={post.data.tag ?? ''}>
              <div class="log-date">{date}</div>
              <div class={`tag ${post.data.tag ?? ''}`}>{post.data.tag ?? ''}</div>
              <div class="log-title">{post.data.title}</div>
              <div class="log-read">[ read ]</div>
            </a>
          );
        })}
      </div>

      <div class="pagination" id="pagination">
        <button class="page-link" id="prev-btn">&lt; prev dir</button>
        <div class="page-numbers" id="page-numbers"></div>
        <button class="page-link" id="next-btn">next dir &gt;</button>
      </div>

    </main>
    <Footer />
  </body>
</html>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.log-row'));
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const pageNumbersContainer = document.getElementById('page-numbers') as HTMLElement;

  const ITEMS_PER_PAGE = 5; // Change this to whatever you want
  let currentPage = 1;
  let currentFilter = 'all';
  let filteredRows = [...rows];

  function updateView() {
    // 1. Apply active filter
    filteredRows = rows.filter(row => {
      if (currentFilter === 'all') return true;
      return row.dataset.tag === currentFilter;
    });

    // 2. Calculate pagination logic
    const totalPages = Math.ceil(filteredRows.length / ITEMS_PER_PAGE) || 1;
    if (currentPage > totalPages) currentPage = totalPages;

    // 3. Hide all rows, then show only current page slice
    rows.forEach(row => row.style.display = 'none');
    
    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;
    
    filteredRows.slice(start, end).forEach(row => {
      row.style.display = '';
    });

    // 4. Update Pagination UI
    prevBtn.style.visibility = currentPage === 1 ? 'hidden' : 'visible';
    nextBtn.style.visibility = currentPage === totalPages ? 'hidden' : 'visible';

    // Inject page numbers
    pageNumbersContainer.innerHTML = '';
    for (let i = 1; i <= totalPages; i++) {
      const span = document.createElement('span');
      if (i === currentPage) {
        span.classList.add('current');
        span.textContent = `[ ${i} ]`;
      } else {
        const a = document.createElement('button');
        a.classList.add('page-link');
        a.textContent = i.toString();
        a.addEventListener('click', () => {
          currentPage = i;
          updateView();
        });
        span.appendChild(a);
      }
      pageNumbersContainer.appendChild(span);
    }
  }

  // Handle Category Filter Clicks
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentFilter = btn.dataset.filter ?? 'all';
      currentPage = 1; // Always reset to page 1 on filter

      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      updateView();
    });
  });

  // Handle Prev/Next Clicks
  prevBtn.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; updateView(); }
  });
  
  nextBtn.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredRows.length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) { currentPage++; updateView(); }
  });

  // Initialize
  updateView();
</script>

<style>
  main { flex: 1; padding: 4rem 5vw; max-width: 1000px; margin: 0 auto; width: 100%; }
  
  h1 { font-family: 'JetBrains Mono', monospace; font-size: clamp(3rem, 6vw, 5rem); font-weight: 800; margin-bottom: 2rem; text-transform: lowercase; }
  main h1::before { content: "> "; color: var(--neon); }

  .filters { display: flex; gap: 1.5rem; margin-bottom: 3rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
  .filter-btn { background: none; border: none; color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; cursor: pointer; transition: color 0.2s; padding: 0; }
  .filter-btn::before { content: "--"; opacity: 0.5; }
  .filter-btn:hover { color: var(--text); }
  .filter-btn.active { color: var(--neon); font-weight: 700; }

  .log-list { display: flex; flex-direction: column; }
  .log-row { display: grid; grid-template-columns: 120px 100px 1fr auto; gap: 2rem; padding: 1.5rem 0; border-bottom: 1px dashed var(--border); text-decoration: none; color: var(--text); transition: all 0.2s; align-items: center; }
  .log-row:hover { border-bottom-color: var(--neon); padding-left: 1rem; background: rgba(255,255,255,0.02); }
  .log-date { color: var(--muted); font-size: 0.85rem; }
  .log-title { font-weight: 700; text-transform: lowercase; font-size: 1.1rem; }
  .log-read { color: var(--neon); font-size: 0.85rem; opacity: 0; transition: opacity 0.2s; }
  .log-row:hover .log-read { opacity: 1; }

  .tag { padding: 0.2rem 0.5rem; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; text-align: center; min-width: 60px; }
  .tag.tutorial { background: var(--neon); color: var(--bg); }
  .tag.article { background: var(--article); color: #fff; }

  /* Pagination Styling */
  .pagination { display: flex; justify-content: space-between; align-items: center; margin-top: 4rem; font-size: 0.85rem; color: var(--muted); }
  .page-link { color: var(--text); background: none; border: none; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; cursor: pointer; text-decoration: none; transition: color 0.2s; }
  .page-link:hover { color: var(--neon); }
  .page-numbers span { margin: 0 0.5rem; }
  .page-numbers .current { color: var(--neon); font-weight: 700; }

  @media (max-width: 800px) {
    .log-row { grid-template-columns: 1fr; gap: 0.5rem; padding: 1.5rem 0; }
    .log-date { order: 2; }
    .tag { order: 1; width: fit-content; }
    .log-title { order: 3; }
    .log-read { display: none; }
  }
</style>