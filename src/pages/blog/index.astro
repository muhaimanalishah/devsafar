---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import '../../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <div class="noise"></div>
    <Header />
    <main>
      <h1>archive.</h1>
      <div class="filters">
        <button class="filter-btn active" data-filter="all">all</button>
        <button class="filter-btn" data-filter="tutorial">tutorials</button>
        <button class="filter-btn" data-filter="article">articles</button>
      </div>
      <div class="log-list">
        {posts.map(post => {
          const date = post.data.pubDate.toISOString().split('T')[0];
          return (
            <a href={`/blog/${post.id}`} class="log-row" data-tag={post.data.tag ?? ''}>
              <div class="log-date">{date}</div>
              <div class={`tag ${post.data.tag ?? ''}`}>{post.data.tag ?? ''}</div>
              <div class="log-title">{post.data.title}</div>
              <div class="log-read">[ read ]</div>
            </a>
          );
        })}
      </div>
    </main>
    <Footer />
  </body>
</html>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const rows = document.querySelectorAll<HTMLElement>('.log-row');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      // Update active button
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Show/hide rows
      rows.forEach(row => {
        if (filter === 'all') {
          row.style.display = '';
        } else {
          row.style.display = row.dataset.tag === filter ? '' : 'none';
        }
      });
    });
  });
</script>

<style>
  main {
    flex: 1;
    padding: 4rem 5vw;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }
  h1 {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    margin-bottom: 2rem;
    text-transform: lowercase;
  }

  main h1::before { content: "> "; color: var(--neon); }

  .filters {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .filter-btn {
    background: none;
    border: none;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    cursor: pointer;
    transition: color 0.2s;
    padding: 0;
  }
  .filter-btn::before { content: "--"; opacity: 0.5; }
  .filter-btn:hover { color: var(--text); }
  .filter-btn.active { color: var(--neon); font-weight: 700; }

  .log-list { display: flex; flex-direction: column; }
  .log-row {
    display: grid;
    grid-template-columns: 120px 100px 1fr auto;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px dashed var(--border);
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
    align-items: center;
  }
  .log-row:hover { border-bottom-color: var(--neon); padding-left: 1rem; background: rgba(255,255,255,0.02); }
  .log-date { color: var(--muted); font-size: 0.85rem; }
  .log-title { font-weight: 700; text-transform: lowercase; font-size: 1.1rem; }
  .log-read { color: var(--neon); font-size: 0.85rem; opacity: 0; transition: opacity 0.2s; }
  .log-row:hover .log-read { opacity: 1; }

  .tag {
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    text-align: center;
    min-width: 60px;
  }
  .tag.tutorial { background: var(--neon); color: var(--bg); }
  .tag.article { background: var(--article); color: #fff; }

  @media (max-width: 800px) {
    .log-row { grid-template-columns: 1fr; gap: 0.5rem; padding: 1.5rem 0; }
    .log-date { order: 2; }
    .tag { order: 1; width: fit-content; }
    .log-title { order: 3; }
    .log-read { display: none; }
  }
</style>