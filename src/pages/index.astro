---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <div class="noise"></div>
    <Header />
    <main>
      <div class="hero">
        <div class="massive-text">SAFAR</div>
        <div class="content">
          <div class="tag">index.js</div>
          <h1>building.<br />breaking.<br />learning.</h1>
          <p>writing code and fixing bugs. this is my space to document the process and share what i learn along the way.</p>
          <div class="cmd">> npm run dev</div>
        </div>
      </div>

      <section class="logs-section">
        <div class="section-title">./recent_logs</div>
        <div class="log-list">
          {posts.map(post => {
            const date = post.data.pubDate.toISOString().split('T')[0];
            return (
              <a href={`/blog/${post.id}`} class="log-row">
                <div class="log-date">{date}</div>
                <div class="log-title">{post.data.title}</div>
                <div class="log-read">[ read ]</div>
              </a>
            );
          })}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main { flex: 1; }

  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 0 5vw;
  }
  .massive-text {
    position: absolute;
    font-family: 'Syne', sans-serif;
    font-size: 20vw;
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.05);
    line-height: 0.8;
    letter-spacing: -0.05em;
    top: 20%; left: -2%;
    user-select: none;
    pointer-events: none;
  }
  .content { position: relative; z-index: 2; max-width: 600px; }
  .tag {
    display: inline-block;
    background: var(--neon);
    color: var(--bg);
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  h1 {
    font-size: clamp(2.5rem, 5vw, 5rem);
    margin: 0 0 1.5rem 0;
    line-height: 1.1;
    text-transform: lowercase;
  }
  p { font-size: 1rem; color: #aaa; border-left: 2px solid var(--neon); padding-left: 1rem; }
  .cmd { margin-top: 1.5rem; display: inline-block; font-size: 0.9rem; color: var(--neon); }

  .logs-section { padding: 5rem 5vw; border-top: 1px solid var(--border); }
  .section-title { font-size: 0.85rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 3rem; }

  .log-row {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px dashed var(--border);
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
  }
  .log-row:hover { border-bottom-color: var(--neon); padding-left: 1rem; }
  .log-date { color: var(--muted); font-size: 0.85rem; }
  .log-title { font-weight: 700; text-transform: lowercase; }
  .log-read { color: var(--neon); font-size: 0.85rem; opacity: 0; transition: opacity 0.2s; }
  .log-row:hover .log-read { opacity: 1; }

  @media (max-width: 800px) {
    .log-row { grid-template-columns: 1fr; gap: 0.5rem; }
    .log-read { display: none; }
  }
</style>