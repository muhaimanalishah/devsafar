---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostLog from '../components/PostLog.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={'home'} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <Header />
    <main>
      <div class="hero">
        <div class="massive-text safar-text">SAFAR</div>
        <div class="content">
          <div class="hero-tag">on_the_road.sh</div>
          <h1>start.<br />safar.<br />repeat.</h1>
          <p>
            capturing the chaos of modern web development and translating it
            into lessons. seekhte seekhte sikhana—teaching while still learning.
          </p>
          <div class="cmd">{'>'} git switch -b learning</div>
        </div>
      </div>

      <section class="logs-section">
        <div class="section-title">./recent_logs</div>
        <div class="log-list">
          {
            posts.map((post) => {
              const date = post.data.pubDate.toISOString().split('T')[0];
              return (
                <PostLog
                  id={post.id}
                  date={date}
                  tag={post.data.tag}
                  title={post.data.title}
                />
              );
            })
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    flex: 1;
  }

  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 0 5vw;
  }
  .massive-text {
    position: absolute;
    font-family: 'Syne', sans-serif;
    font-size: 20vw;
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05);
    line-height: 0.8;
    letter-spacing: -0.05em;
    z-index: 1;
    user-select: none;
    pointer-events: none;
  }
  .safar-text {
    top: 30%;
    left: -5%;
    font-size: 20vw;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.07);
  }

  .content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    mix-blend-mode: difference;
  }
  .hero-tag {
    display: inline-block;
    background: var(--neon);
    color: var(--bg);
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
  }
  .content h1 {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(3.5rem, 6vw, 6rem);
    font-weight: 800;
    margin: 0 0 1.5rem 0;
    line-height: 1.1;
    text-transform: lowercase;
  }
  p {
    font-size: 1rem;
    color: #aaa;
    border-left: 2px solid var(--neon);
    padding-left: 1rem;
  }
  .cmd {
    margin-top: 1.5rem;
    display: inline-block;
    font-size: 0.9rem;
    color: var(--neon);
  }

  .logs-section {
    padding: 5rem 5vw;
    border-top: 1px solid var(--border);
  }
  .section-title {
    font-size: 0.85rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 3rem;
  }
  @media (max-width: 600px) {
    .safar-text {
      font-size: 52vw;
      top: 8%;
      left: -5%;
      width: 2ch;
      word-break: break-all;
    }
    .hero {
      overflow: hidden;
    }
    .section-title {
      margin-bottom: 1rem;
    }
  }
  @media (min-width: 601px) and (max-width: 900px) {
    .safar-text {
      font-size: 34vw;
      top: 20%;
      left: -3%;
      width: 3ch;
      word-break: break-all;
    }
    .hero {
      overflow: hidden;
    }
  }
</style>
